# Scanner2Email
SECRET_KEY=change-this-to-a-random-secret
DATABASE_URL=sqlite:///scanner2email.db

# OAuth - create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - create at https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OAuth - create at https://developer.apple.com/
APPLE_CLIENT_ID=

# Stripe - get at https://dashboard.stripe.com/
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_ENTERPRISE=

# Server
FLASK_ENV=production
PORT=5000
