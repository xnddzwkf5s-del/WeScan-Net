# Scanner2Email
SECRET_KEY=change-this-to-a-random-secret
DATABASE_URL=sqlite:///wescan.db

# OAuth - create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - create at https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OAuth - create at https://developer.apple.com/
APPLE_CLIENT_ID=

# Stripe - get at https://dashboard.stripe.com/
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_ENTERPRISE=

# Per-currency per-plan prices (set each in Stripe Dashboard)
STRIPE_PRICE_PRO_AUD=
STRIPE_PRICE_PRO_USD=
STRIPE_PRICE_PRO_EUR=
STRIPE_PRICE_PRO_GBP=
STRIPE_PRICE_BUS_AUD=
STRIPE_PRICE_BUS_USD=
STRIPE_PRICE_BUS_EUR=
STRIPE_PRICE_BUS_GBP=
STRIPE_PRICE_ENT_AUD=
STRIPE_PRICE_ENT_USD=
STRIPE_PRICE_ENT_EUR=
STRIPE_PRICE_ENT_GBP=

# Server
FLASK_ENV=production
PORT=5000
